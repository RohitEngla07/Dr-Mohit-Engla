---
interface Props {
  id?: string;
  label?: string;
  title: string;
  description?: string;
  class?: string;
  align?: "left" | "center";
}

const {
  id,
  label,
  title,
  description,
  class: className = "",
  align = "left",
} = Astro.props;

const alignClass = align === "center" ? "text-center mx-auto" : "";
---

<section id={id} class={`scroll-mt-24 py-20 sm:py-28 ${className}`}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class={`reveal max-w-2xl ${alignClass}`}>
      {
        label && (
          <p class="section-label">
            {label}
          </p>
        )
      }
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl lg:text-[2.75rem] lg:leading-[1.1]">
        {title}
      </h2>
      {
        description && (
          <p class="mt-4 text-lg leading-relaxed text-[var(--color-ink-muted)]">
            {description}
          </p>
        )
      }
    </div>
    <div class="reveal reveal-delay-1 mt-12 sm:mt-14">
      <slot />
    </div>
  </div>
</section>
