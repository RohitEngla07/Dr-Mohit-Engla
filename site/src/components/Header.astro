---
import { siteConfig } from "../data/site";

const navLinks = [
  { href: "#about", label: "About" },
  { href: "#credentials", label: "Experience" },
  { href: "#services", label: "Services" },
  { href: "#research", label: "Expertise" },
  { href: "#book", label: "Book" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)]/60 bg-[var(--color-surface)]/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="group min-w-0">
      <span class="block truncate text-base font-bold tracking-tight text-[var(--color-ink)] sm:text-lg">
        Dr. Mohit Engla
      </span>
      <span class="hidden text-xs text-[var(--color-ink-subtle)] sm:block">
        General Surgeon · Indore
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-full px-3.5 py-2 text-sm font-medium text-[var(--color-ink-muted)] transition hover:bg-white hover:text-[var(--color-ink)]"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2">
      <a href={`tel:${siteConfig.contact.phone}`} class="btn-secondary hidden !min-h-10 !px-4 !py-2 !text-sm sm:inline-flex">
        Call
      </a>
      <a href="#book" class="btn-primary !min-h-10 !px-5 !py-2 !text-sm">
        Book now
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border)] bg-white text-[var(--color-ink)] lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-[var(--color-border)] bg-white px-4 py-4 lg:hidden"
    aria-label="Mobile navigation"
  >
    <ul class="space-y-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block rounded-xl px-4 py-3 text-sm font-medium text-[var(--color-ink-muted)] transition hover:bg-[var(--color-accent-light)] hover:text-[var(--color-accent-dark)]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
