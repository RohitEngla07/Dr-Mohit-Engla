---
import { siteConfig } from "../data/site";
import { faqs } from "../data/content";

const whatsappUrl = `https://wa.me/${siteConfig.contact.phone.replace(/\D/g, "")}?text=${encodeURIComponent(siteConfig.contact.whatsappMessage)}`;
---

<section id="appointments" class="scroll-mt-24 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="reveal overflow-hidden rounded-[2rem] bg-[var(--color-ink)] text-white shadow-[var(--shadow-lift)]">
      <div class="grid lg:grid-cols-2">
        <div class="p-8 sm:p-12 lg:p-14">
          <p class="section-label !text-teal-300 before:!bg-teal-400">Book a visit</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            Schedule your consultation
          </h2>
          <p class="mt-4 max-w-md text-base leading-relaxed text-white/70">
            Use the booking form at the top of this page, or reach out by phone or WhatsApp — we'll confirm a convenient time at {siteConfig.clinic.name}.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#book" class="btn-primary !bg-white !text-[var(--color-ink)] !shadow-none hover:!bg-white/90">
              Go to booking form
            </a>
            <a href={`tel:${siteConfig.contact.phone}`} class="btn-secondary !border-white/20 !bg-white/10 !text-white hover:!bg-white/20">
              Call {siteConfig.contact.phoneDisplay}
            </a>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary !border-white/20 !bg-white/10 !text-white hover:!bg-white/20">
              WhatsApp
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 divide-y divide-white/10 border-t border-white/10 sm:grid-cols-3 sm:divide-x sm:divide-y-0 sm:border-t-0 lg:grid-cols-1 lg:divide-x-0 lg:divide-y">
          <a href="#book" class="group flex flex-col justify-center p-6 transition hover:bg-white/5 sm:p-8">
            <span class="text-xs font-medium uppercase tracking-wide text-white/50">Online form</span>
            <span class="mt-1 text-lg font-semibold">Book at top of page →</span>
          </a>
          <a href={`tel:${siteConfig.contact.phone}`} class="group flex flex-col justify-center p-6 transition hover:bg-white/5 sm:p-8">
            <span class="text-xs font-medium uppercase tracking-wide text-white/50">Phone</span>
            <span class="mt-1 text-lg font-semibold">{siteConfig.contact.phoneDisplay}</span>
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="group flex flex-col justify-center p-6 transition hover:bg-white/5 sm:p-8">
            <span class="text-xs font-medium uppercase tracking-wide text-white/50">WhatsApp</span>
            <span class="mt-1 text-lg font-semibold">Send a message →</span>
          </a>
        </div>
      </div>
    </div>

    {
      siteConfig.clinic.practoUrl && (
        <div class="reveal reveal-delay-1 mt-6 card-static p-6 text-center">
          <a
            href={siteConfig.clinic.practoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Book on Practo
          </a>
        </div>
      )
    }

    <div class="reveal reveal-delay-2 mt-12 grid gap-6 lg:grid-cols-2">
      <div class="card-static p-6 sm:p-8">
        <h3 class="text-sm font-semibold text-[var(--color-ink)]">Clinic information</h3>
        <dl class="mt-5 space-y-4">
          <div>
            <dt class="text-xs font-medium text-[var(--color-ink-subtle)]">Location</dt>
            <dd class="mt-0.5 font-medium text-[var(--color-ink)]">{siteConfig.clinic.name}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-[var(--color-ink-subtle)]">Address</dt>
            <dd class="mt-0.5 font-medium text-[var(--color-ink)]">
              {
                siteConfig.clinic.addressLines.map((line) => (
                  <>
                    {line}
                    <br />
                  </>
                ))
              }
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-[var(--color-ink-subtle)]">Hours</dt>
            <dd class="mt-0.5 font-medium text-[var(--color-ink)]">{siteConfig.clinic.hours}</dd>
          </div>
        </dl>
        <a
          href={siteConfig.clinic.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary mt-6 !text-sm"
        >
          Open in Google Maps →
        </a>
      </div>

      <div class="card-static overflow-hidden">
        <iframe
          title="D21 Clinic location map — Indore"
          src={siteConfig.clinic.mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0; min-height: 280px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-full min-h-[280px] w-full"
        ></iframe>
      </div>
    </div>

    <div class="reveal reveal-delay-3 mt-12">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Common questions</h3>
      <div class="mt-5 divide-y divide-[var(--color-border)] rounded-[var(--radius-card)] border border-[var(--color-border)] bg-white">
        {
          faqs.map((faq) => (
            <details class="group px-5 py-4 sm:px-6">
              <summary class="cursor-pointer list-none font-medium text-[var(--color-ink)] marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="flex items-center justify-between gap-4">
                  {faq.question}
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-surface)] text-[var(--color-accent)] transition group-open:rotate-45">+</span>
                </span>
              </summary>
              <p class="mt-3 pb-1 text-sm leading-relaxed text-[var(--color-ink-muted)]">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
