---
import SectionHeading from "./SectionHeading.astro";
import {
  qualifications,
  experience,
  certifications,
  clinicalSkills,
} from "../data/content";
---

<SectionHeading
  id="credentials"
  label="Experience"
  title="Training you can trust"
  description="Qualified, certified, and experienced across leading hospitals in Madhya Pradesh."
  class="bg-white"
>
  <div class="grid gap-6 lg:grid-cols-12 lg:gap-8">
    <div class="reveal lg:col-span-5">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Qualifications</h3>
      <ul class="mt-4 space-y-3">
        {
          qualifications.map((item) => (
            <li class="card-static flex items-start justify-between gap-4 p-5">
              <div>
                <p class="font-semibold text-[var(--color-ink)]">{item.degree}</p>
                <p class="mt-1 text-sm text-[var(--color-ink-muted)]">{item.institution}</p>
              </div>
              <span class="shrink-0 rounded-full bg-[var(--color-accent-light)] px-3 py-1 text-xs font-semibold text-[var(--color-accent-dark)]">
                {item.year}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="reveal reveal-delay-1 lg:col-span-7">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Career timeline</h3>
      <ol class="relative mt-4 space-y-0">
        {
          experience.map((item, index) => (
            <li class={`relative pl-8 pb-8 ${index < experience.length - 1 ? "border-l border-[var(--color-border)]" : ""}`}>
              <span
                class="absolute -left-[5px] top-1 h-2.5 w-2.5 rounded-full bg-[var(--color-accent)] ring-4 ring-[var(--color-accent-light)]"
                aria-hidden="true"
              />
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">{item.period}</p>
              <p class="mt-1 font-semibold text-[var(--color-ink)]">{item.role}</p>
              <p class="text-sm text-[var(--color-ink-muted)]">{item.organization}</p>
              <ul class="mt-3 space-y-1">
                {item.highlights.slice(0, 2).map((highlight) => (
                  <li class="text-sm text-[var(--color-ink-muted)]">· {highlight}</li>
                ))}
              </ul>
            </li>
          ))
        }
      </ol>
    </div>
  </div>

  <div class="reveal reveal-delay-2 mt-10 grid gap-6 lg:grid-cols-2">
    <div class="card-static p-6">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Certifications</h3>
      <ul class="mt-4 space-y-2.5">
        {
          certifications.map((cert) => (
            <li class="flex gap-2.5 text-sm text-[var(--color-ink-muted)]">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {cert}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="card-static p-6">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Clinical expertise</h3>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          clinicalSkills.map((skill) => (
            <li class="rounded-full bg-[var(--color-surface)] px-3.5 py-1.5 text-sm font-medium text-[var(--color-ink-muted)] ring-1 ring-[var(--color-border)]">
              {skill}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</SectionHeading>
