---
import { trustStats } from "../data/content";

const delayClasses = ["", " reveal-delay-1", " reveal-delay-2", " reveal-delay-3"];
---

<section class="border-y border-[var(--color-border)] bg-white" aria-label="Professional highlights">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 divide-x divide-[var(--color-border)] lg:grid-cols-4">
      {
        trustStats.map((stat, i) => (
          <div class={`reveal${delayClasses[i] ?? ""} px-4 py-8 text-center sm:px-6`}>
            <p class="text-2xl font-bold tracking-tight text-[var(--color-accent)] sm:text-3xl">
              {stat.value}
            </p>
            <p class="mt-1 text-xs leading-snug text-[var(--color-ink-muted)] sm:text-sm">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
