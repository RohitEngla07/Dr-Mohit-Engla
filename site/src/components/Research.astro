---
import SectionHeading from "./SectionHeading.astro";
import { publications, thesis, conferences } from "../data/content";
---

<SectionHeading
  id="research"
  label="Expertise"
  title="Research & recognition"
  description="Published work and national conference presentations that reflect surgical depth and ongoing learning."
  class="bg-white"
>
  <div class="grid gap-6 lg:grid-cols-5 lg:gap-8">
    <div class="reveal lg:col-span-3">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Publications</h3>
      <ul class="mt-4 space-y-3">
        {
          publications.map((pub) => (
            <li class="card-static p-5 sm:p-6">
              <p class="font-semibold leading-snug text-[var(--color-ink)]">{pub.title}</p>
              <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{pub.authors}</p>
              <p class="mt-1 text-sm italic text-[var(--color-ink-subtle)]">{pub.journal}</p>
              <p class="mt-2 inline-block rounded-full bg-[var(--color-accent-light)] px-2.5 py-0.5 text-xs font-medium text-[var(--color-accent-dark)]">
                {pub.details}
              </p>
            </li>
          ))
        }
      </ul>

      <div class="card-static mt-4 border-l-4 border-l-[var(--color-accent)] p-5 sm:p-6">
        <p class="text-xs font-semibold text-[var(--color-accent)]">{thesis.type}</p>
        <p class="mt-2 text-sm font-medium leading-relaxed text-[var(--color-ink)]">{thesis.title}</p>
      </div>
    </div>

    <div class="reveal reveal-delay-1 lg:col-span-2">
      <h3 class="text-sm font-semibold text-[var(--color-ink)]">Conferences</h3>
      <ul class="mt-4 space-y-3">
        {
          conferences.slice(0, 4).map((item) => (
            <li class="card-static p-4">
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-[var(--color-surface)] px-2 py-0.5 text-xs font-medium text-[var(--color-ink-muted)] ring-1 ring-[var(--color-border)]">
                  {item.type}
                </span>
                {item.date && (
                  <span class="text-xs text-[var(--color-ink-subtle)]">{item.date}</span>
                )}
              </div>
              <p class="mt-2 text-sm font-semibold text-[var(--color-ink)]">{item.title}</p>
              <p class="mt-0.5 text-xs text-[var(--color-ink-muted)]">
                {item.event}{item.location && ` · ${item.location}`}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</SectionHeading>
