---
import SectionHeading from "./SectionHeading.astro";
import { services } from "../data/content";

const icons: Record<string, string> = {
  scope: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  alert: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
  heart: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  microscope: "M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z",
};
---

<SectionHeading
  id="services"
  label="Services"
  title="Surgical care tailored to you"
  description="From routine consultations to emergency evaluation — individualized treatment after a full clinical assessment."
>
  <div class="grid gap-4 sm:grid-cols-2 lg:gap-6">
    {
      services.map((service, i) => (
        <article
          id={service.id}
          class={`card reveal ${i % 2 === 1 ? "reveal-delay-1" : ""} group flex flex-col p-6 sm:p-8 ${i === 0 ? "sm:row-span-1 lg:p-10" : ""}`}
        >
          <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[var(--color-accent-light)] text-[var(--color-accent)] transition group-hover:bg-[var(--color-accent)] group-hover:text-white">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={icons[service.icon]} />
            </svg>
          </div>
          <h3 class="mt-5 text-xl font-bold tracking-tight text-[var(--color-ink)]">
            {service.title}
          </h3>
          <p class="mt-2 text-sm font-medium text-[var(--color-accent)]">{service.summary}</p>
          <p class="mt-4 flex-1 text-sm leading-relaxed text-[var(--color-ink-muted)]">
            {service.description}
          </p>
          <a
            href="#book"
            class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] transition group-hover:gap-2"
          >
            Book consultation
            <span aria-hidden="true">→</span>
          </a>
        </article>
      ))
    }
  </div>
</SectionHeading>
