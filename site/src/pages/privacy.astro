---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
---

<BaseLayout
  title={`Privacy Policy — ${siteConfig.name}`}
  description="Privacy policy for Dr. Mohit Engla's personal website."
  canonicalPath="/privacy"
>
  <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:px-8">
    <p class="section-label">Legal</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl">Privacy Policy</h1>
    <p class="mt-4 text-sm text-[var(--color-ink-subtle)]">Last updated: July 2026</p>

    <div class="mt-10 space-y-8 text-[var(--color-ink-muted)]">
      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">Overview</h2>
        <p>
          This website ({siteConfig.url}) is operated by {siteConfig.name}. We
          respect your privacy and collect only information you voluntarily
          provide when contacting us.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">Information we collect</h2>
        <p>
          When you use the contact form, email, phone, or WhatsApp, you may
          share your name, phone number, email address, and message content. We
          use this information solely to respond to your inquiry.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">How we use information</h2>
        <ul class="list-disc space-y-2 pl-5">
          <li>To respond to appointment requests and inquiries</li>
          <li>To provide information about surgical services</li>
          <li>To improve communication with patients and colleagues</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">Data sharing</h2>
        <p>
          We do not sell, rent, or trade your personal information. Data is not
          shared with third parties except as required by law or to facilitate
          your requested communication (e.g., email or WhatsApp providers).
        </p>
      </section>

      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">Medical information</h2>
        <p>
          Please do not share detailed medical records or sensitive health
          information through the website contact form. For clinical matters,
          schedule a consultation through phone or WhatsApp.
        </p>
      </section>

      <section>
        <h2 class="text-lg font-bold text-[var(--color-ink)]">Contact</h2>
        <p>
          For privacy-related questions, contact{" "}
          <a href={`mailto:${siteConfig.contact.email}`} class="font-medium text-[var(--color-accent)] hover:underline">
            {siteConfig.contact.email}
          </a>.
        </p>
      </section>

      <p>
        <a href="/" class="font-medium text-[var(--color-accent)] hover:underline">← Back to home</a>
      </p>
    </div>
  </div>
</BaseLayout>
